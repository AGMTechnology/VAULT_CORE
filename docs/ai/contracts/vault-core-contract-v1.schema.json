{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vault-core.local/schema/contract/v1",
  "title": "VAULT_CORE Contract v1",
  "description": "Execution contract generated by Contract Hub before agent run.",
  "type": "object",
  "required": [
    "meta",
    "scope",
    "acceptance",
    "testPlan",
    "executionPolicy",
    "memoryContext",
    "skillsBundle",
    "rulesBundle",
    "docsChecklist",
    "qualityGates"
  ],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "contractId",
        "projectId",
        "version",
        "priority",
        "status",
        "assignee",
        "createdAt"
      ],
      "additionalProperties": false,
      "properties": {
        "contractId": { "type": "string", "minLength": 1 },
        "projectId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "const": "v1" },
        "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
        "status": { "type": "string", "enum": ["to-qualify", "ready", "in-progress", "in-review", "done", "blocked", "ask-boss"] },
        "assignee": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "format": "date-time" },
        "sourceTicketId": { "type": "string" }
      }
    },
    "scope": {
      "type": "object",
      "required": ["title", "type", "summary"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["feature", "story", "task", "bug", "chore"] },
        "summary": { "type": "string", "minLength": 1 },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "labels": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "testPlan": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "executionPolicy": {
      "type": "object",
      "required": ["tddRequired", "singleCommitScope", "evidenceCommentRequired"],
      "additionalProperties": false,
      "properties": {
        "tddRequired": { "type": "boolean", "const": true },
        "singleCommitScope": { "type": "boolean" },
        "evidenceCommentRequired": { "type": "string", "enum": ["[DEV_DONE]"] },
        "askBossOnBlocker": { "type": "boolean", "default": true }
      }
    },
    "memoryContext": {
      "type": "object",
      "required": ["entries", "sourceSessionIds", "fallbackUsed"],
      "additionalProperties": false,
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "lessonCategory", "content"],
            "additionalProperties": true,
            "properties": {
              "id": { "type": "string" },
              "lessonCategory": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "sourceSessionIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fallbackUsed": { "type": "boolean" }
      }
    },
    "skillsBundle": {
      "type": "object",
      "required": ["skills"],
      "additionalProperties": false,
      "properties": {
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["skillId", "version"],
            "additionalProperties": false,
            "properties": {
              "skillId": { "type": "string" },
              "version": { "type": "string" }
            }
          }
        }
      }
    },
    "rulesBundle": {
      "type": "object",
      "required": ["rules"],
      "additionalProperties": false,
      "properties": {
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ruleId", "severity", "description"],
            "additionalProperties": false,
            "properties": {
              "ruleId": { "type": "string" },
              "severity": { "type": "string", "enum": ["info", "warning", "error", "blocker"] },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "docsChecklist": {
      "type": "object",
      "required": ["requiredDocs"],
      "additionalProperties": false,
      "properties": {
        "requiredDocs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reviewedDocs": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "qualityGates": {
      "type": "object",
      "required": ["beforeInProgress", "beforeInReview", "beforeDone"],
      "additionalProperties": false,
      "properties": {
        "beforeInProgress": {
          "type": "array",
          "items": { "type": "string" }
        },
        "beforeInReview": {
          "type": "array",
          "items": { "type": "string" }
        },
        "beforeDone": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
